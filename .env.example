# Copy to .env and fill in the values you need.

DOCFLOW_AGENT_APP__NAME=docflow-agent
DOCFLOW_AGENT_APP__TITLE=Document Processing Service
DOCFLOW_AGENT_APP__ENV=local
DOCFLOW_AGENT_APP__DEBUG=false

DOCFLOW_AGENT_API__HOST=127.0.0.1
DOCFLOW_AGENT_API__PORT=8000
DOCFLOW_AGENT_API__RELOAD=false

DOCFLOW_AGENT_LLM__PROVIDER=stub
DOCFLOW_AGENT_LLM__MODEL=gpt-4o-mini
DOCFLOW_AGENT_LLM__TEMPERATURE=0.0
DOCFLOW_AGENT_LLM__BASE_URL=
DOCFLOW_AGENT_LLM__TIMEOUT_SECONDS=30
DOCFLOW_AGENT_LLM__MAX_RETRIES=2
DOCFLOW_AGENT_LLM__API_KEY=
